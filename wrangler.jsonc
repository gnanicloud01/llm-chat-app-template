/**
 * For more details on how to configure Wrangler, refer to:
 * https://developers.cloudflare.com/workers/wrangler/configuration/
 */
{
	"$schema": "node_modules/wrangler/config-schema.json",
	"name": "aigret",
	"main": "src/index.ts",
	"compatibility_date": "2025-10-08",
	"compatibility_flags": [
		"nodejs_compat",
		"global_fetch_strictly_public"
	],
	"assets": {
		"binding": "ASSETS",
		"directory": "./dist"
	},
	"observability": {
		"enabled": true
	},
	"ai": {
		"binding": "AI"
	},
	"d1_databases": [
		{
			"binding": "DB",
			"database_name": "gt-ai-db",
			"database_id": "4b02432f-394d-4f33-a074-2bbbb1327194"
		}
	],
	"r2_buckets": [
		{
			"binding": "BUCKET",
			"bucket_name": "gt-ai-storage"
		}
	],
	"upload_source_maps": true
}