{
	"name": "llm-chat-app-template",
	"description": "A simple chat application powered by Cloudflare Workers AI",
	"cloudflare": {
		"label": "LLM Chat App",
		"products": [
			"Workers",
			"Workers AI",
			"AI Gateway"
		],
		"categories": [
			"ai"
		],
		"docs_url": "https://developers.cloudflare.com/workers-ai/",
		"preview_icon_url": "https://imagedelivery.net/wSMYJvS3Xw-n339CbDyDIA/a974bd55-20c6-4656-fa29-1551d43ddc00/public",
		"preview_image_url": "https://imagedelivery.net/wSMYJvS3Xw-n339CbDyDIA/65dd8441-89d3-491d-c5a1-0a000d070700/preview",
		"publish": true
	},
	"devDependencies": {
		"@cloudflare/vitest-pool-workers": "0.10.11",
		"@cloudflare/workers-types": "^4.20250425.0",
		"@types/node": "24.10.1",
		"@vitejs/plugin-react": "^5.1.4",
		"concurrently": "^9.2.1",
		"typescript": "5.9.3",
		"vite": "^7.3.1",
		"vitest": "3.2.4",
		"wrangler": "^4.69.0"
	},
	"private": true,
	"scripts": {
		"build": "vite build",
		"cf-typegen": "wrangler types",
		"check": "tsc --noEmit && wrangler deploy --dry-run",
		"deploy": "wrangler deploy",
		"dev": "npm run dev:all",
		"dev:all": "npx concurrently \"npm run dev:backend\" \"npm run dev:frontend\"",
		"dev:backend": "wrangler dev --port 8787 --ip 127.0.0.1",
		"dev:frontend": "vite --port 3000",
		"start": "npm run dev:all",
		"test": "vitest"
	},
	"dependencies": {
		"dompurify": "^3.2.4",
		"firebase": "^12.10.0",
		"highlight.js": "^11.11.1",
		"marked": "^15.0.7",
		"react": "^19.2.4",
		"react-dom": "^19.2.4",
		"react-router-dom": "^7.13.1"
	}
}